{
  "name": "painstorm-wod-checker",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "hot-update": "DOTENV_CONFIG_PATH=.env.hotupdater node -r dotenv/config node_modules/.bin/hot-updater deploy -i",
    "cp": "bun install && bun hot-update",
    "cp-console": "yarn hot-updater console"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hot-updater/cloudflare": "0.35.1",
    "@hot-updater/expo": "0.35.1",
    "@hot-updater/react-native": "0.35.1",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/react-query": "^5.87.1",
    "dotenv": "^17.4.2",
    "expo": "^57.0.0",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-media-library": "~57.0.1",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "^3.3.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "wrangler": "^4.107.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.4",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~57.0.0",
    "hot-updater": "0.35.1",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
