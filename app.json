{
  "expo": {
    "name": "페인스톰 WOD",
    "slug": "painstorm-wod-checker",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "painstormwodchecker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.dowoniandev.painstormwodchecker",
      "config": {
        "usesNonExemptEncryption": false
      },
      "appleTeamId": "3KRU4KNBMV",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "이미지 저장을 위해 사진 보관함에 저장 권한이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "io.dowoniandev.painstormwodchecker",
      "versionCode": 3,
      "googleServicesFile": "./google-services-android.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-3.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-notifications",
      [
        "@hot-updater/react-native",
        {
          "channel": "production"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "13538e91-9d8f-4753-8a5b-f33f930c003c"
      },
      "router": {}
    },
    "owner": "dowoniandev"
  }
}
